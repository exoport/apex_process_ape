{{define "page"}}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{.Title}}</title>
<link rel="stylesheet" href="/assets/styles.css">
<script src="/assets/vendor/htmx.min.js"></script>
<script src="/assets/vendor/htmx-ext-sse.min.js"></script>
</head>
<body hx-ext="sse" sse-connect="/api/events"
      hx-on::sse-open="document.getElementById('status').textContent='connected'; document.getElementById('status').className='connected'"
      hx-on::sse-error="document.getElementById('status').textContent='disconnected'; document.getElementById('status').className='disconnected'">
<header>
  <h1>{{.Title}}</h1>
  <small>{{.Subtitle}}</small>
  <div id="status">connecting…</div>
  <button id="stop-btn"
          hx-post="/api/stop"
          hx-confirm="Stop the active step? Step state will be marked stopped and the run will halt."
          hx-swap="none">stop</button>
</header>

<!-- Sentinel listener. Every named SSE event is enumerated here so
     HTMX runs its OOB-swap machinery on the response body. The
     'connected' event is emitted from ReplayEvents on every new SSE
     subscriber and swaps the #status banner deterministically — that
     covers the case where the browser's htmx event names diverge
     from what hx-on:: matches. -->
<div sse-swap="connected,pipeline-init,stage-start,stage-update,stage-end,stage-fail,hook,reply,await-pending,await-resolved,stopped,error"
     hx-swap="none"></div>

<section>
  <h2>stages</h2>
  <div id="stages">
    {{range .Stages}}<div id="stage-{{.Slug}}" class="stage pending"><div class="stage-head"><span class="stage-glyph">·</span><span class="stage-name">{{.Name}}</span></div><div class="stage-last-hook">pending</div></div>{{end}}
  </div>
</section>

<section>
  <h2>activity</h2>
  <ul id="hooks"></ul>
</section>

{{if eq .Mode "chat"}}
<section>
  <h2>replies</h2>
  <div id="replies"></div>
</section>

<form id="decision-gate"
      hx-post="/api/send"
      hx-ext="json-enc"
      hx-swap="none">
  <span class="gate-label" id="gate-label">(waiting for skill to call await_message)</span>
  <input type="text" name="content" placeholder="reply…" disabled>
  <button type="submit" disabled>send</button>
</form>
{{end}}

<script src="/assets/app.js"></script>
</body>
</html>
{{end}}
