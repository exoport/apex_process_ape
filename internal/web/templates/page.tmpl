{{define "page"}}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{.Title}}</title>
<link rel="stylesheet" href="/assets/styles.css">
<script src="/assets/vendor/htmx.min.js"></script>
<script src="/assets/vendor/htmx-ext-sse.min.js"></script>
</head>
<body hx-ext="sse" sse-connect="/api/events"
      hx-on::sse-open="document.getElementById('status').textContent='connected'; document.getElementById('status').className='connected'"
      hx-on::sse-error="document.getElementById('status').textContent='disconnected'; document.getElementById('status').className='disconnected'">
<header>
  <h1>{{.Title}}</h1>
  <small>{{.Subtitle}}</small>
  <div id="status">connecting…</div>
  <button id="stop-btn"
          hx-post="/api/stop"
          hx-confirm="Stop the active step? Step state will be marked stopped and the run will halt."
          hx-swap="none"
          hidden>stop</button>
</header>

<!-- Sentinel listener. Every named SSE event we emit is listed here so
     HTMX runs its OOB-swap machinery on the response body. hx-swap="none"
     means this div's own contents are never replaced; the fragments
     target #stages / #hooks / #replies / #decision-gate / #status via
     hx-swap-oob inside the response. The connected/disconnected status
     flip lives on <body> because the SSE extension fires its open /
     error events on the sse-connect host (body), and those events
     don't bubble down to a descendant. Defence in depth: app.js also
     attaches a document-level listener. -->
<div sse-swap="pipeline-init,stage-start,stage-update,stage-end,stage-fail,hook,reply,await-pending,await-resolved,stopped,error"
     hx-swap="none"></div>

<section>
  <h2>stages</h2>
  <div id="stages"></div>
</section>

<section>
  <h2>activity</h2>
  <ul id="hooks"></ul>
</section>

<section>
  <h2>replies</h2>
  <div id="replies"></div>
</section>

<form id="decision-gate"
      hx-post="/api/send"
      hx-ext="json-enc"
      hx-swap="none">
  <span class="gate-label" id="gate-label">(waiting for skill to call await_message)</span>
  <input type="text" name="content" placeholder="reply…" disabled>
  <button type="submit" disabled>send</button>
</form>

<script src="/assets/app.js"></script>
</body>
</html>
{{end}}
